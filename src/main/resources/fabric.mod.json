{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "A Hypixel Skyblock mod with some enhancements for the game not found in the big mods ",
  "authors": [
    "Kd_Gaming1"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/skyblock-enhancements",
    "sources": "https://github.com/KdGaming0/SkyBlock-Enhancements"
  },
  "license": "PolyForm Shield License 1.0.0",
  "icon": "assets/skyblock_enhancements/logo.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "com.github.kd_gaming1.skyblockenhancements.SkyblockEnhancements"
    ],
    "rrv": [
      "com.github.kd_gaming1.skyblockenhancements.compat.rrv.SkyblockRrvPlugin"
    ],
    "rrv_client": [
      "com.github.kd_gaming1.skyblockenhancements.compat.rrv.SkyblockRrvClientPlugin"
    ]
  },
  "mixins": [
    "skyblock_enhancements.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabricloader}",
    "fabric-api": ">=${fabric_api}",
    "minecraft": "${minecraft}",
    "uilib": ">=${ui_lib}"
  },
  "suggests": {
    "modernui": "*",
    "rrv": "*"
  }
}